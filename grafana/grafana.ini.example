[smtp]
enabled = true
host = smtp.gmail.com:587
user = your-email@gmail.com
password = your-app-password
from_address = your-email@gmail.com
from_name = Grafana Monitoring
skip_verify = false

[server]
;domain = localhost
;root_url = %(protocol)s://%(domain)s:%(http_port)s/
;http_addr = 0.0.0.0
;http_port = 3000

[security]
;admin_user = admin
;admin_password = admin
